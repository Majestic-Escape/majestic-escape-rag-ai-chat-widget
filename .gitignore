# ─── Dependencies & build output ──────────────────────────────────────────────
node_modules
.pnp
.pnp.*
.yarn/install-state.gz
.next
out
dist
build
*.tsbuildinfo
next-env.d.ts
.turbo
.swc
.cache

# Vite embed bundle output — `npm run build:embed` regenerates this on every
# Railway deploy. The whole subdir is build artefacts:
#   - widget.js (~308 kB compiled bundle)
#   - embed-sandbox.html (vite copies it from public/ into the outDir)
# The SOURCE for the sandbox lives at public/embed-sandbox.html and IS tracked.
public/embed/

# ─── Environment files (NEVER commit) ─────────────────────────────────────────
# .env.example is committed as a template — explicitly NOT ignored.
.env
.env.*
!.env.example

# ─── Secrets / credentials ────────────────────────────────────────────────────
# Defensive — block common secret-ish files even if someone forgets the .env naming.
*.pem
*.key
*.p12
*.pfx
*.crt
*.cert
secrets/
secret/
credentials.json
service-account*.json

# ─── Logs ─────────────────────────────────────────────────────────────────────
*.log
logs/
npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*

# ─── Editor / OS ──────────────────────────────────────────────────────────────
.DS_Store
Thumbs.db
.vscode/
!.vscode/extensions.json
.idea/
*.swp
*.swo

# ─── Test / coverage / playwright artefacts ──────────────────────────────────
coverage/
.nyc_output/
playwright-report/
playwright/.cache/
.playwright-mcp/
test-results/

# Screenshots: ignore random ones at the root, but allow the curated set
# in docs/screenshots/ which the README links to.
# Regression/test screenshots (phase*-prefixed) are artefacts — not committed.
*.png
!docs/screenshots/*.png
docs/screenshots/phase*.png

# ─── Local archives / scratch ────────────────────────────────────────────────
_archive_*
scratch/
tmp/
*.tmp

# ─── Vercel / deploy ─────────────────────────────────────────────────────────
.vercel
