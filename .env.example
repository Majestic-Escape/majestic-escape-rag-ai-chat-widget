# Copy this file to `.env.local` and fill in the real values.
# `.env.local` is gitignored — never commit it.

# ─── Required ─────────────────────────────────────────────────────────────────

# Gemini Developer API key (https://aistudio.google.com/apikey)
GEMINI_API_KEY=

# MongoDB Atlas connection string. Must include the database name in the path
# (e.g. mongodb+srv://user:pass@cluster.mongodb.net/master-db?retryWrites=true&w=majority)
MONGODB_URI=

# JWT signing key. MUST match the value used by server.me so logged-in users
# on majesticescape.in are trusted by this service without a separate auth flow.
JWT_SECRET=

# ─── Recommended (resilience) ─────────────────────────────────────────────────

# Fallback AI providers — used when Gemini hits a 429 quota error.
# Either or both can be omitted; the route returns a friendly error if all fail.
GROQ_API_KEY=
XAI_API_KEY=

# ─── Admin allow-list ─────────────────────────────────────────────────────────
# Until admin.site's JWTs include `role: "admin"`, paste either the admin's
# email or their MongoDB userId here. Comma-separated for multiple admins.

ADMIN_EMAILS=
ADMIN_USER_IDS=

# ─── Cost guardrails ──────────────────────────────────────────────────────────
# Daily soft caps on /api/chat per identity (resets every 24h on container
# restart). Bounds Gemini token spend even if an attacker rotates IPs.

DAILY_AI_LIMIT_USER=200
DAILY_AI_LIMIT_IP=30

# ─── Networking ───────────────────────────────────────────────────────────────

# Comma-separated browser origins allowed to connect (Socket.IO + /api/chat).
ALLOWED_ORIGINS=https://majesticescape.in,https://admin.majesticescape.in,http://localhost:3000,http://localhost:3001

# Where the chat widget links property cards to. Production: https://majesticescape.in
NEXT_PUBLIC_PROPERTY_BASE_URL=https://majesticescape.in

# Socket.IO endpoint for the user.website chat widget. Leave empty in
# production to use window.location.origin; set to http://localhost:3003
# in dev when running this service alongside user.website on different ports.
NEXT_PUBLIC_SUPPORT_SOCKET_URL=

# Local dev port. Railway injects PORT automatically — do NOT set it on Railway.
PORT=3003
